		lineageTag: d1ab66a2-e24d-403b-b645-1744ea7044d1
		formatString: 0.00
		displayFolder: Risk

	measure 'Worst Max Drawdown' = MINX('fact_security_snapshot', 'fact_security_snapshot'[max_drawdown])
