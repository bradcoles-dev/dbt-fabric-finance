		displayFolder: Risk

	measure 'Avg Sharpe Ratio' = AVERAGEX(FILTER('fact_security_snapshot', NOT ISBLANK('fact_security_snapshot'[sharpe_ratio])), 'fact_security_snapshot'[sharpe_ratio])
		lineageTag: 928b0ac9-5771-4581-a4ae-ce61d9678a91
